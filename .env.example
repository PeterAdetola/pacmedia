APP_NAME="The Pacmedia"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://thepacmedia.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=pacmedia
DB_USERNAME=sail
DB_PASSWORD=password

FORWARD_DB_PORT=3310


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mail.thepacmedia.com
MAIL_PORT=587
MAIL_USERNAME=reach@thepacmedia.com
MAIL_PASSWORD=reach@pacmediaEmailLogin
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=reach@thepacmedia.com
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_RECEIVER_EMAIL=reach@thepacmedia.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

ADMIN_NAME="Admin User"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password


VITE_APP_NAME="${APP_NAME}"

# Google — console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=google-client-id-code
GOOGLE_CLIENT_SECRET=google-client-secret-code
GOOGLE_REDIRECT_URI=google-redirect-uri

# LinkedIn — linkedin.com/developers → Create App → Auth tab
LINKEDIN_CLIENT_ID=linkedin-client-id
LINKEDIN_CLIENT_SECRET=linkedin-client-secret
LINKEDIN_REDIRECT_URI=linkedin-redirect-uri

# GitHub — github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=github-client-id-code
GITHUB_CLIENT_SECRET=github-client-secret-code
GITHUB_REDIRECT_URI=github-redirect-uri
